# Local SQLite database file (created automatically by `prisma db push`).
DATABASE_URL="file:./dev.db"

# Supabase project credentials are required for auth to work and are NOT
# committed here (see .env.local, which is gitignored). Create your own
# free Supabase project at supabase.com, then add a .env.local with:
#   NEXT_PUBLIC_SUPABASE_URL=https://<your-project>.supabase.co
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon/public key>
#   SUPABASE_SERVICE_ROLE_KEY=<service_role key -- keep secret, server-only>
